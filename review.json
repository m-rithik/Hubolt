    {
      "fingerprint": "fp_8b3fb5738da8c99c",
      "ruleId": "security.credential-leak-via-untrusted-base-url",
      "title": "Credential leakage via arbitrary Jira baseUrl in untrusted repository configuration",
      "message": "The configuration schema allows repository-defined URL values (specifically integrations.jira.baseUrl) to resolve integration endpoints. When processing untrusted repository content, such as a pull request branch, an attacker can specify an arbitrary URL (like https://attacker.com). When a user runs 'hubolt issues create', the integration transmits the user's Jira API token ('HUBOLT_JIRA_TOKEN') and email directly to this attacker-controlled server in the 'Authorization' header.",
      "category": "security",
      "severity": "high",
      "confidenceLabel": "high",
      "source": "llm",
      "range": {
        "file": "src/integrations/jira.ts",
        "startLine": 17,
        "endLine": 67,
        "diffSide": "right"
      },
      "evidence": [
        "const base = (options.baseUrl ?? \"\").replace(/\\/+$/, \"\");",
        "const auth = Buffer.from(`${options.email}:${options.apiToken}`).toString(\"base64\");",
        "const response = await fetchImpl(`${base}/rest/api/2/issue`, {",
        "headers: { \"content-type\": \"application/json\", authorization: `Basic ${auth}` },"
      ],
      "impact": "Allows an untrusted repository configuration (e.g. from a malicious fork or PR) to exfiltrate sensitive Jira personal API tokens and user emails to a third-party server under the attacker's control.",
      "suggestion": "Resolve the Jira 'baseUrl' from a secure, machine-level environment variable (e.g., 'HUBOLT_JIRA_BASE_URL') rather than repository-level configuration, or strictly validate that the 'baseUrl' matches a whitelisted domain pattern (e.g., '*.atlassian.net') before sending credentials.",
      "verification": "Set HUBOLT_JIRA_TOKEN and integrations.jira.enabled: true in .hubolt.yml. Configure integrations.jira.baseUrl to an external mock server (e.g., webhook.site). Run 'hubolt issues create' and verify that the credentials are sent to the mock server.",
      "relatedSignals": [],
      "tags": []
    }
  ],
