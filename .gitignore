# Credential material (never commit private keys or certificates)
*.pem
*.key
*.p12
*.pfx
*.keystore
*.crt
*.cert
*.der
id_rsa
id_ed25519

# Logs and reports (generated review/report artifacts)
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.report.json
*.report.md
report.json
report.md
review.json

# Database backups and deploy state (never commit data dumps)
# NB: do NOT use *.sql here - prisma/migrations/**/migration.sql must stay tracked.
backups/
*.dump
*.sql.gz
.last_deploy

# Test and coverage output
coverage/
.nyc_output/
.vitest/

# Tool caches
.cache/
.eslintcache
.turbo/
.vite/

# Prisma local artifacts
prisma/*.db
prisma/migrations/dev/
src/generated/

# OS and editor files
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
*~

# Local assistant settings
.claude/settings.local.json
.cursor/**/settings.local.json

# Agent and dev guidance kept local
# (If these are team-wide rules, track them instead with: git add -f CLAUDE.md AGENTS.md)
CLAUDE.md
AGENTS.md
.cursor/rules/
.github/copilot-instructions.md

