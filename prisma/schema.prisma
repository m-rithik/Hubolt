generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // LLM the hosted review worker uses for this org. The provider names a
  // gateway-stored credential (provider_credentials); null falls back to the
  // repo config / server env. The model is free-form for the chosen provider.
  reviewLlmProvider String?
  reviewLlmModel    String?

  repos               Repository[]
  members             OrganizationMember[]
  budgets             Budget[]
  apiKeys             ApiKey[]
  providerCredentials ProviderCredential[]
  findingFeedback     FindingFeedback[]
  memoryCards         MemoryCard[]
  reviews             Review[]
  findings            Finding[]
  integrations        RepositoryIntegration[]
  sessions            Session[]
  webhookDeliveries   WebhookDelivery[]

  @@map("organizations")
}

model FindingFeedback {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  repoId      String?
  fingerprint String
  ruleId      String
  severity    String
  category    String?

  verdict String // accepted | dismissed | discussed
  source  String // github-reaction | github-reply | import

  // Idempotency key for collector sources (e.g. gh:rc:123:+1) so re-imports
  // of the same reaction or reply never double-count.
  externalId String?

  actor String?
  role  String?
  note  String?

  createdAt DateTime @default(now())

  @@unique([orgId, externalId])
  @@index([orgId, fingerprint])
  @@index([orgId, ruleId])
  @@map("finding_feedback")
}

model MemoryCard {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Empty string rather than NULL for org-scope/non-rule cards: Postgres
  // treats NULLs as distinct in unique indexes, which would allow duplicates.
  repoId String @default("")
  ruleId String @default("")

  kind  String // rule | style
  title String
  body  String

  tokensEstimate Int     @default(0)
  sourceCount    Int     @default(0)
  // Style cards are maintainer-authored and survive rebuilds.
  pinned         Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, repoId, kind, ruleId])
  @@index([orgId])
  @@map("memory_cards")
}

model OrganizationMember {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // "admin" | "developer". Legacy "viewer" is treated as "developer" in code.
  role String @default("developer")

  apiKeys  ApiKey[]
  accesses RepositoryAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, userId])
  @@map("organization_members")
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?

  // Username/password login. Nullable so existing API-key-only users are
  // unaffected until credentials are set. passwordHash is a scrypt hash.
  username           String?  @unique
  passwordHash       String?
  status             String   @default("active") // active | disabled
  mustChangePassword Boolean  @default(false)

  orgs     OrganizationMember[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Session {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // sha256 of the opaque token; the plaintext is shown to the client once only.
  tokenHash  String    @unique
  expiresAt  DateTime
  lastUsedAt DateTime?
  ip         String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([orgId])
  @@map("sessions")
}

model ApiKey {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name       String
  keyHash    String    @unique @db.VarChar(255)
  lastUsedAt DateTime?

  // Access level for this key. "admin" can change state (register repos, manage
  // keys, set credentials/budgets); "viewer" is read-only. Defaults to admin so
  // existing keys keep working.
  role String @default("admin")

  // Optional owner: the org member this key belongs to. Cleared (not deleted)
  // when the member is removed.
  memberId String?
  member   OrganizationMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@index([keyHash])
  @@index([memberId])
  @@map("api_keys")
}

model Repository {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name     String
  fullName String
  url      String

  // Repository metadata.
  provider      String  @default("github") // github | bitbucket
  workspace     String?
  project       String?
  defaultBranch String?
  environment   String?

  // GitHub App installation that grants access to this repo. Null when the
  // repo is registered but the App is not installed (or no PR has been seen
  // yet); the worker mints an installation token from this id to post reviews.
  installationId String?

  // Set when the repo is removed from the dashboard. Soft-disable preserves the
  // repo's reviews/findings (a hard delete would cascade them away); disabled
  // repos are skipped by the webhook and hidden from the active list.
  disabledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews           Review[]
  findings          Finding[]
  pullRequestStates PullRequestState[]
  integration       RepositoryIntegration?
  accesses          RepositoryAccess[]
  reviewLocks       ReviewLock[]
  ingestLocks       ReviewIngestLock[]

  @@unique([orgId, fullName])
  @@index([fullName])
  @@index([installationId])
  @@map("repositories")
}

model RepositoryIntegration {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Exactly one integration per repository.
  repoId String     @unique
  repo   Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  provider String // github | bitbucket
  name     String // human label, e.g. "Payments Service Bitbucket Connection"

  // Secrets are encrypted at rest (secret-box). The *Fingerprint columns are
  // sha256 of the plaintext and are unique, enforcing "no credential reuse
  // across integrations" without ever decrypting.
  encryptedToken           String
  tokenFingerprint         String  @unique
  tokenLast4               String  @default("")
  encryptedWebhookSecret   String?
  webhookSecretFingerprint String? @unique

  // Optional per-repo Slack incoming webhook. When set, this repo's review
  // notifications go here instead of any common/org-wide Slack webhook.
  encryptedSlackWebhook String?

  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@map("repository_integrations")
}

model RepositoryAccess {
  id     String     @id @default(cuid())
  repoId String
  repo   Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  memberId String
  member   OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  accessLevel String  @default("read") // read | actions
  grantedById String? // member/user id recorded for audit (no FK)

  createdAt DateTime @default(now())

  @@unique([repoId, memberId])
  @@index([memberId])
  @@map("repository_access")
}

model PullRequestState {
  id     String     @id @default(cuid())
  repoId String
  repo   Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  prNumber Int
  headSha  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([repoId, prNumber])
  @@map("pull_request_states")
}

model ReviewLock {
  id     String     @id @default(cuid())
  repoId String
  repo   Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  prNumber Int
  headSha  String
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@unique([repoId, prNumber, headSha])
  @@index([expiresAt])
  @@map("review_locks")
}

model ReviewIngestLock {
  id     String     @id @default(cuid())
  repoId String
  repo   Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  fingerprint String
  expiresAt   DateTime

  createdAt DateTime @default(now())

  @@unique([repoId, fingerprint])
  @@index([expiresAt])
  @@map("review_ingest_locks")
}

model WebhookDelivery {
  id    String       @id @default(cuid())
  orgId String?
  org   Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  provider   String
  deliveryId String
  event      String

  createdAt DateTime @default(now())

  @@unique([provider, deliveryId])
  @@index([createdAt])
  @@index([orgId])
  @@map("webhook_deliveries")
}

model Review {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  repoId String
  repo   Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  fingerprint String
  scope       String
  provider    String
  model       String

  summary      String?
  findingCount Int     @default(0)

  createdAt DateTime @default(now())

  findings        Finding[]
  analyzerSignals AnalyzerSignal[]
  modelUsage      ModelUsage[]

  @@unique([repoId, fingerprint])
  @@index([orgId, createdAt])
  @@index([repoId])
  @@index([createdAt])
  @@map("reviews")
}

model Finding {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  repoId String
  repo   Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  ruleId    String
  message   String
  severity  String
  category  String?
  file      String
  lineStart Int
  lineEnd   Int

  fingerprint String
  confidence  Float  @default(0.5)

  createdAt DateTime @default(now())

  @@unique([reviewId, fingerprint])
  @@index([orgId, createdAt])
  @@index([repoId])
  @@index([reviewId])
  @@index([fingerprint])
  @@index([createdAt])
  @@index([severity])
  @@map("findings")
}

model AnalyzerSignal {
  id       String @id @default(cuid())
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  analyzer  String
  ruleId    String
  message   String
  severity  String
  file      String
  lineStart Int
  lineEnd   Int

  createdAt DateTime @default(now())

  @@index([reviewId])
  @@index([analyzer])
  @@map("analyzer_signals")
}

model ModelUsage {
  id       String @id @default(cuid())
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  provider         String
  model            String
  inputTokens      Int
  outputTokens     Int
  estimatedCostUsd Float  @default(0)

  createdAt DateTime @default(now())

  @@index([reviewId])
  @@map("model_usage")
}

model Budget {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  provider          String
  monthlyLimitUsd   Float
  alertThresholdPct Int    @default(80)

  currentMonthCostUsd Float    @default(0)
  currentMonthResets  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, provider])
  @@map("budgets")
}

// PostgreSQL CHECK constraint handled in migration
// currentMonthCostUsd >= 0

model AuditEvent {
  id    String @id @default(cuid())
  orgId String

  action     String
  resource   String
  resourceId String?
  details    String?

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([createdAt])
  @@index([orgId, createdAt])
  @@map("audit_events")
}

model RateLimitWindow {
  id    String @id @default(cuid())
  orgId String

  provider          String
  model             String
  windowStart       DateTime
  requestCount      Int      @default(0)
  maxRequestsPerDay Int      @default(1000)

  @@unique([orgId, provider, model, windowStart])
  @@map("rate_limit_windows")
}

model ProviderCredential {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  provider     String
  keyHash      String    @db.VarChar(100)
  encryptedKey String
  lastUsedAt   DateTime?

  createdAt DateTime @default(now())

  @@unique([orgId, provider])
  @@index([keyHash])
  @@map("provider_credentials")
}

model ModelRoute {
  id    String @id @default(cuid())
  orgId String

  reviewScope String
  provider    String
  model       String
  priority    Int    @default(0)
  costLimit   Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, reviewScope, provider])
  @@map("model_routes")
}

model GatewayLog {
  id    String @id @default(cuid())
  orgId String

  provider         String
  model            String
  promptTokens     Int
  completionTokens Int
  estimatedCostUsd Float
  cachedResponse   Boolean @default(false)
  duration_ms      Int

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([createdAt])
  @@map("gateway_logs")
}

model GatewayBudgetReservation {
  id    String @id @default(cuid())
  jobId String @unique
  orgId String

  provider         String
  estimatedCostUsd Float
  actualCostUsd    Float?
  status           String    @default("reserved")
  settledAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([status])
  @@map("gateway_budget_reservations")
}
