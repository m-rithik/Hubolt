# Hubolt server environment (production).
#
# Copy this to /opt/hubolt/.env ON THE SERVER and fill in real values:
#   cp deploy/env.example .env && chmod 600 .env
#
# NEVER commit the real .env. This example file is safe to commit; it holds
# placeholders only, no secrets.

# --- Runtime ---
NODE_ENV=production
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info
# Set only when running behind a trusted reverse proxy/load balancer.
# TRUST_PROXY=true

# --- Database (local PostgreSQL installed via apt) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://hubolt:CHANGE_ME_STRONG_PASSWORD@localhost:5432/hubolt_db
# Optional: required only for npm run db:check-drift. Use a separate throwaway DB.
# SHADOW_DATABASE_URL=postgresql://hubolt:CHANGE_ME_STRONG_PASSWORD@localhost:5432/hubolt_shadow

# --- Redis (local, installed via apt) ---
REDIS_URL=redis://localhost:6379

# --- LLM provider ---
HUBOLT_LLM_PROVIDER=
HUBOLT_LLM_MODEL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Hubolt server / API ---
HUBOLT_SERVER_URL=
HUBOLT_API_KEY=
# 32-byte key used to encrypt stored credentials. Generate once, keep stable:
#   openssl rand -base64 32
CREDENTIAL_MASTER_KEY=

# --- GitHub App (only if you use the GitHub integration) ---
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_WEBHOOK_SECRET=
# Multi-line PEM. Keep it on one line using \n escapes per your loader.
GITHUB_APP_PRIVATE_KEY=

# --- Notifications (optional) ---
# Hosted webhook reviews use repo-scoped encrypted Slack webhooks from the dashboard.
# These env webhooks are for CLI/local single-tenant workflows.
HUBOLT_SLACK_WEBHOOK_URL=
HUBOLT_TEAMS_WEBHOOK_URL=
