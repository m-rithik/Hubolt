{
  "name": "hubolt",
  "version": "0.2.1",
  "description": "Context-aware AI code review assistant that is local-first, not local-only.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "hubolt": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "prisma/schema.prisma",
    "prisma/migrations/",
    "docs/",
    ".hubolt.example.yml",
    "docker-compose.yml"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m-rithik/hubolt.git"
  },
  "bugs": {
    "url": "https://github.com/m-rithik/hubolt/issues"
  },
  "homepage": "https://github.com/m-rithik/hubolt#readme",
  "keywords": [
    "ai",
    "code-review",
    "github",
    "cli",
    "security",
    "llm",
    "typescript"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean && npx prisma generate",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "chmod +x dist/cli/index.js",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test && npm audit --omit=dev",
    "dev": "tsx src/cli/index.ts",
    "dev:server": "tsx src/server/index.ts",
    "server": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "db:start": "docker-compose up -d",
    "db:stop": "docker-compose down",
    "db:reset": "npx prisma migrate reset --force",
    "db:migrate": "npx prisma migrate deploy",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/openai": "^3.0.67",
    "@clack/prompts": "^1.5.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ai": "^6.0.195",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.8.5",
    "pg": "^8.21.0",
    "picomatch": "^4.0.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "safe-regex2": "^5.1.1",
    "tree-sitter-wasms": "^0.1.13",
    "typescript": "^5.7.2",
    "web-tree-sitter": "^0.20.8",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/picomatch": "^4.0.3",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "@prisma/dev": "0.24.10"
  }
}
